{
  "name": "turnos-medicos-mvp",
  "version": "1.0.0",
  "description": "MVP de gestion de turnos medicos para clinica (FastAPI + React + JSON)",
  "scripts": {
    "install:backend": "python -m pip install -r backend/requirements.txt",
    "install:all": "npm install --workspaces",
    "dev:backend": "npm --workspace backend run start:dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace backend run build; npm --workspace frontend run build",
    "db:seed": "npm --workspace backend run db:seed"
  },
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
