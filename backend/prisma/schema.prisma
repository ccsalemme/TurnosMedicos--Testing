generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
  NO_SHOW
}

model User {
  id                   String        @id @default(uuid())
  email                String        @unique
  passwordHash         String
  role                 Role
  isActive             Boolean       @default(true)
  firstName            String
  lastName             String
  phone                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  patientProfile       PatientProfile?
  doctorProfile        DoctorProfile?
  appointmentsAsPatient Appointment[] @relation("PatientAppointments")
  appointmentsAsDoctor  Appointment[] @relation("DoctorAppointments")
  createdAppointments   Appointment[] @relation("AppointmentCreatedBy")
  updatedAppointments   Appointment[] @relation("AppointmentUpdatedBy")
  createdBlocks         ScheduleBlock[] @relation("BlockCreatedBy")
  auditLogs             AuditLog[]      @relation("AuditActor")
}

model PatientProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  document   String   @unique
  birthDate  DateTime
  phone      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id            String          @id @default(uuid())
  userId         String          @unique
  licenseNumber  String          @unique
  siteId         String?
  bio            String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  site           ClinicSite?     @relation(fields: [siteId], references: [id])
  specialties    DoctorSpecialty[]
  availabilities Availability[]
  blocks         ScheduleBlock[]
}

model Specialty {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  durationMinutes Int              @default(30)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  doctors         DoctorSpecialty[]
  appointments    Appointment[]
}

model DoctorSpecialty {
  doctorId    String
  specialtyId String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialty   Specialty     @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([doctorId, specialtyId])
}

model ClinicSite {
  id           String        @id @default(uuid())
  name         String
  address      String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  doctors      DoctorProfile[]
  appointments Appointment[]

  @@unique([name, address])
}

model Availability {
  id        String        @id @default(uuid())
  doctorId  String
  weekday   Int
  startTime String
  endTime   String
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, weekday, isActive])
}

model ScheduleBlock {
  id          String        @id @default(uuid())
  doctorId     String
  startAt      DateTime
  endAt        DateTime
  reason       String?
  createdById  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  doctor       DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("BlockCreatedBy", fields: [createdById], references: [id])

  @@index([doctorId, startAt, endAt])
}

model Appointment {
  id                String            @id @default(uuid())
  patientId         String
  doctorId          String
  specialtyId       String
  siteId            String
  startAt           DateTime
  endAt             DateTime
  status            AppointmentStatus @default(PENDING)
  notes             String?
  cancellationReason String?
  createdById       String
  updatedById       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  patient           User              @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor            User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  specialty         Specialty         @relation(fields: [specialtyId], references: [id])
  site              ClinicSite        @relation(fields: [siteId], references: [id])
  createdBy         User              @relation("AppointmentCreatedBy", fields: [createdById], references: [id])
  updatedBy         User?             @relation("AppointmentUpdatedBy", fields: [updatedById], references: [id])

  @@index([doctorId, status, startAt])
  @@index([patientId, status, startAt])
  @@index([status, startAt])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor     User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entity, createdAt])
  @@index([action, createdAt])
}
