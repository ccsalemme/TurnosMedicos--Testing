PORT=3000
MOCK_MODE=true
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/turnos_medicos?schema=public"
JWT_SECRET="change_this_secret"
JWT_EXPIRES_IN="8h"
CORS_ORIGIN="http://localhost:5173"
DEFAULT_CANCELLATION_WINDOW_HOURS=24
# Set to true on locked-down corporate machines to boot API without initial DB handshake
PRISMA_SKIP_CONNECT_ON_STARTUP=false
